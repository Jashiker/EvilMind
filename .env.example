# ============================================================
# Truth Hunter (邪恶思潮) 配置文件
# 复制此文件为 .env 并填入真实值: cp .env.example .env
# ============================================================

# ── DeepSeek API (必填) ──
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── 模型配置 ──
PRIMARY_MODEL=deepseek-v4-pro
SECONDARY_MODEL=deepseek-v4-pro
VISION_MODEL=deepseek-v4-pro

# ── Claude Code CLI (Agent 搜索工具) ──
# Docker 中 claude CLI 通过 DeepSeek Anthropic 兼容 API 调用
# 默认复用 DEEPSEEK_API_KEY，也可单独指定
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# ── Firecrawl API (可选) ──
FIRECRAWL_API_KEY=

# ── 百度飞桨OCR (图片审查功能，可选) ──
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
AISTUDIO_OCR_URL=

# ── 服务配置 ──
HOST=0.0.0.0
PORT=8000

# ── 知识库配置 ──
SIMILARITY_THRESHOLD=0.3

# ── 搜索配置 ──
MAX_SEARCH_RESULTS=5
